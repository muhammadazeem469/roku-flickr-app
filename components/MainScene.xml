<?xml version="1.0" encoding="utf-8"?>
<component name="MainScene" extends="Scene">
    <interface>
        <field id="appBgColor" type="string" />
        <field id="appTextColor" type="string" />
    </interface>

    <children>
        <Label
            id="appTitle"
            text="Flickr Gallery"
            translation="[960, 60]"
            horizAlign="center"
            font="font:LargeSystemFont"
        />

        <Label
            id="loadingLabel"
            text="Loading..."
            translation="[960, 540]"
            horizAlign="center"
            vertAlign="center"
            font="font:MediumSystemFont"
        />

        <LayoutGroup
            id="swimlaneContainer"
            translation="[60, 150]"
            layoutDirection="vert"
            itemSpacings="[40]"
            visible="false"
        />
    </children>

    <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
</component>