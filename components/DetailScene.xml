<?xml version="1.0" encoding="utf-8"?>
<!-- ******************************************************
  ** DetailScene.xml
  ** Detail view component for displaying a single image with metadata
  ** Shows large image, title, description, and metadata
  ** NOTE: This is a Group component, not a Scene!
  ****************************************************** -->

<component name="DetailScene" extends="Group">
    <interface>
        <!-- Input: ImageModel from MainScene -->
        <field id="imageModel" type="assocarray" />

        <!-- Output: Signal when user wants to go back -->
        <field id="closeRequested" type="bool" alwaysNotify="true" />
    </interface>

    <children>
        <!-- Full-screen overlay to capture all input -->
        <Rectangle
            id="overlay"
            width="1920"
            height="1080"
            color="0x000000"
            opacity="0.0"
            focusable="true"
        />

        <!-- Background (on top of overlay) -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000"
        />

        <!-- Main Content Container (visible when loaded) -->
        <Group id="contentGroup" visible="false">

            <!-- Large Image Display (Left side) -->
            <Poster
                id="largeImage"
                translation="[60, 100]"
                width="1200"
                height="720"
                loadDisplayMode="scaleToFit"
                failedBitmapUri=""
            />

            <!-- Metadata Panel (Right side) -->
            <Rectangle
                id="metadataPanel"
                translation="[1300, 100]"
                width="560"
                height="920"
                color="0x0D0D0DFF"
            />

            <!-- Pink accent bar at top of metadata panel -->
            <Rectangle
                id="panelAccent"
                translation="[1300, 100]"
                width="560"
                height="4"
                color="0xFF6B9DFF"
            />

            <!-- Title: wraps to 2 lines max; ellipsizeOnBoundary adds ... on the last line
                 No explicit height — Roku auto-sizes to the visible lines so the
                 height constraint never fights with ellipsizeOnBoundary -->
            <Label
                id="titleLabel"
                translation="[1340, 120]"
                width="480"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                wrap="true"
                maxLines="2"
                ellipsizeOnBoundary="true"
            />

            <!-- Description section header — sits 40px below max title height (2 lines ~80px → y=240) -->
            <Label
                id="descriptionHeader"
                translation="[1340, 238]"
                text="Description"
                font="font:MediumBoldSystemFont"
                color="0xFF6B9DFF"
            />

            <!-- Divider below description header (header ~30px tall → y=268 + 8px gap = 276) -->
            <Rectangle
                id="descDivider"
                translation="[1340, 276]"
                width="480"
                height="1"
                color="0x2A2A2AFF"
            />

            <!-- Description text — 14px below divider -->
            <Label
                id="descriptionLabel"
                translation="[1340, 290]"
                width="480"
                height="168"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
                wrap="true"
            />

            <!-- Details section header — 20px below description text (290+168=458 + 20 = 478) -->
            <Label
                id="metadataHeader"
                translation="[1340, 478]"
                text="Details"
                font="font:MediumBoldSystemFont"
                color="0xFF6B9DFF"
            />

            <!-- Divider below Details heading (478 + 30px header height + 8px gap = 516) -->
            <Rectangle
                id="detailsDivider"
                translation="[1340, 516]"
                width="480"
                height="1"
                color="0x2A2A2AFF"
            />

            <!-- Owner — first label below divider, 14px gap (516 + 14 = 530) -->
            <Label
                id="ownerLabel"
                translation="[1340, 530]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
            />

            <!-- Dimensions — 32px below owner (530 + 32 = 562) -->
            <Label
                id="dimensionsLabel"
                translation="[1340, 562]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
            />

            <!-- File Size — 32px below dimensions (562 + 32 = 594) -->
            <Label
                id="fileSizeLabel"
                translation="[1340, 594]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
            />

            <!-- Upload Date — 32px below file size (594 + 32 = 626) -->
            <Label
                id="dateLabel"
                translation="[1340, 626]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
            />

            <!-- Views — 32px below date (626 + 32 = 658) -->
            <Label
                id="viewsLabel"
                translation="[1340, 658]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
            />

            <!-- Comments (if available) — 32px below views (658 + 32 = 690) -->
            <Label
                id="commentsLabel"
                translation="[1340, 690]"
                width="480"
                font="font:SmallSystemFont"
                color="0xCCCCCCFF"
                visible="false"
            />

            <!-- Back Button Hint -->
            <Label
                id="backHint"
                translation="[1340, 980]"
                text="← BACK to return"
                font="font:SmallSystemFont"
                color="0x666666FF"
            />
        </Group>

        <!-- Loading State -->
        <Group id="loadingGroup" visible="true">
            <!-- Custom dot-ring spinner — BusySpinner requires pkg:/images/spinner.png
                 which does not exist and is unreliable across firmware versions.
                 Mirrors the approach used in MainScene. -->
            <Group
                id="loadingSpinner"
                translation="[960, 510]"
            >
                <Rectangle translation="[-4.0, -34.0]" width="8" height="8" color="0xFFFFFFFF" />
                <Rectangle translation="[11.0, -30.0]" width="8" height="8" color="0xFFFFFFE9" />
                <Rectangle translation="[22.0, -19.0]" width="8" height="8" color="0xFFFFFFD4" />
                <Rectangle translation="[26.0, -4.0]" width="8" height="8" color="0xFFFFFFBF" />
                <Rectangle translation="[22.0, 11.0]" width="8" height="8" color="0xFFFFFFAA" />
                <Rectangle translation="[11.0, 22.0]" width="8" height="8" color="0xFFFFFF94" />
                <Rectangle translation="[-4.0, 26.0]" width="8" height="8" color="0xFFFFFF7F" />
                <Rectangle translation="[-19.0, 22.0]" width="8" height="8" color="0xFFFFFF6A" />
                <Rectangle translation="[-30.0, 11.0]" width="8" height="8" color="0xFFFFFF55" />
                <Rectangle translation="[-34.0, -4.0]" width="8" height="8" color="0xFFFFFF3F" />
                <Rectangle translation="[-30.0, -19.0]" width="8" height="8" color="0xFFFFFF2A" />
                <Rectangle translation="[-19.0, -30.0]" width="8" height="8" color="0xFFFFFF15" />
            </Group>
            <Animation
                id="spinnerAnim"
                duration="1.0"
                easeFunction="linear"
                repeat="true"
            >
                <FloatFieldInterpolator
                    key="[0.0, 1.0]"
                    keyValue="[0.0, 6.283185]"
                    fieldToInterp="loadingSpinner.rotation"
                />
            </Animation>
            <Label
                id="loadingLabel"
                translation="[0, 570]"
                width="1920"
                text="Loading image details..."
                horizAlign="center"
                font="font:MediumSystemFont"
                color="0xCCCCCC"
            />
        </Group>

        <!-- Error State -->
        <Group id="errorGroup" visible="false">
            <Label
                id="errorLabel"
                translation="[960, 500]"
                width="1200"
                height="100"
                horizAlign="center"
                vertAlign="center"
                font="font:MediumSystemFont"
                color="0xFF6666FF"
                wrap="true"
            />
            <Label
                id="errorHint"
                translation="[960, 600]"
                text="Press BACK to return"
                horizAlign="center"
                font="font:SmallSystemFont"
                color="0x888888"
            />
        </Group>
        <Rectangle
            id="focusOverlay"
            width="1920"
            height="1080"
            color="0x000000"
            opacity="0.0"
            focusable="true"
        />
    </children>

    <!-- Script Dependencies -->

    <!-- Config -->
    <script type="text/brightscript" uri="pkg:/source/config/AppConfig.brs" />
    <script type="text/brightscript" uri="pkg:/source/config/NetworkConfig.brs" />
    <script type="text/brightscript" uri="pkg:/source/config/UIConfig.brs" />
    <script type="text/brightscript" uri="pkg:/source/config/ImageConfig.brs" />

    <!-- Network/Utils -->
    <script type="text/brightscript" uri="pkg:/source/utils/TypeUtils.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/FormatUtils.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/NetworkUtils.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/ImageUrlBuilder.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/ImageUrlBuilder_Extended.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/ApiHelper.brs" />

    <!-- Network Layer -->
    <script type="text/brightscript" uri="pkg:/source/network/NetworkValidator.brs" />
    <script type="text/brightscript" uri="pkg:/source/network/RetryManager.brs" />
    <script type="text/brightscript" uri="pkg:/source/network/ErrorHandler.brs" />
    <script type="text/brightscript" uri="pkg:/source/network/JsonParser.brs" />
    <script type="text/brightscript" uri="pkg:/source/network/HttpClient.brs" />

    <!-- Models -->
    <script type="text/brightscript" uri="pkg:/source/models/ImageModel.brs" />
    <script type="text/brightscript" uri="pkg:/source/models/ImageMapper.brs" />

    <!-- Services -->
    <script type="text/brightscript" uri="pkg:/source/utils/ResponseBuilder.brs" />
    <script type="text/brightscript" uri="pkg:/source/services/FlickrService_ResponseParser.brs" />
    <script type="text/brightscript" uri="pkg:/source/services/FlickrService_ApiMethods.brs" />
    <script type="text/brightscript" uri="pkg:/source/services/FlickrService.brs" />

    <!-- ViewModels -->
    <script type="text/brightscript" uri="pkg:/source/viewmodels/DetailViewModel_InfoParser.brs" />
    <script type="text/brightscript" uri="pkg:/source/viewmodels/DetailViewModel_InfoLoader.brs" />
    <script type="text/brightscript" uri="pkg:/source/viewmodels/DetailViewModel_StateManager.brs" />
    <script type="text/brightscript" uri="pkg:/source/viewmodels/DetailViewModel.brs" />

    <!-- Scene Logic -->
    <script type="text/brightscript" uri="pkg:/components/DetailScene.brs" />

</component>