<?xml version="1.0" encoding="utf-8"?>
<!-- ******************************************************
  ** ImageCard.xml
  ** Reusable image card component with focus states
  ** Ticket: FG-013
  ****************************************************** -->

<component name="ImageCard" extends="Group" focusable="true">
    <interface>
        <!-- Data fields -->
        <field id="imageModel" type="assocarray" alwaysNotify="true" />
        <field id="showTitle" type="boolean" value="false" />

        <!-- RowList item protocol: set by RowList when itemComponentName is used -->
        <field id="itemContent" type="node" />

        <!-- Size configuration — matches RowList rowItemSize -->
        <field id="cardWidth"  type="float" value="280" />
        <field id="cardHeight" type="float" value="210" />
    </interface>

    <children>
        <!-- Background/Container -->
        <Rectangle
            id="cardBackground"
            width="280"
            height="210"
            color="0x000000"
            opacity="0.0"
        />

        <!-- Dark placeholder shown in all non-image states -->
        <Rectangle
            id="placeholder"
            width="280"
            height="210"
            color="0x1A1A1AFF"
            visible="true"
        />

        <!-- "Loading..." shown while the API request is in progress -->
        <Label
            id="loadingTextLabel"
            text="Loading..."
            width="280"
            height="210"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallSystemFont"
            color="0x888888FF"
            visible="false"
        />

        <!-- Circular arrow retry icon shown after a load failure -->
        <Poster
            id="retryIconPoster"
            uri="pkg:/images/retry_icon.png"
            width="80"
            height="80"
            translation="[100, 40]"
            loadDisplayMode="scaleToFit"
            visible="false"
        />

        <!-- Hint shown below retry icon -->
        <Label
            id="retryHintLabel"
            text="Press OK to retry"
            translation="[0, 140]"
            width="280"
            height="42"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallSystemFont"
            color="0xAAAAAAFF"
            visible="false"
        />

        <!-- Error indicator for image download failures -->
        <Label
            id="errorLabel"
            text="✕"
            width="280"
            height="210"
            horizAlign="center"
            vertAlign="center"
            font="font:LargeSystemFont"
            color="0xFF4444FF"
            visible="false"
        />

        <!-- Thumbnail Image -->
        <Poster
            id="thumbnail"
            width="280"
            height="210"
            loadDisplayMode="scaleToZoom"
            loadingBitmapOpacity="0.0"
            failedBitmapOpacity="0.0"
            visible="false"
        />

        <!-- Title Label (below image) -->
        <Label
            id="titleLabel"
            translation="[0, 215]"
            width="280"
            height="40"
            horizAlign="center"
            vertAlign="top"
            font="font:SmallSystemFont"
            color="0xFFFFFF"
            visible="false"
            wrap="true"
            maxLines="2"
            ellipsizeOnBoundary="true"
        />
    </children>

    <script type="text/brightscript" uri="pkg:/components/ImageCard/ImageCard.brs" />
</component>
